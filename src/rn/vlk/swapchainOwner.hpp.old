#pragma once

#include <vulkan/vulkan.hpp>

namespace rn {

namespace vlk {

class SwapchainOwner {
public:
	vk::SwapchainKHR handle{};
	vk::SurfaceKHR surface{};

	SwapchainOwner() = default;
	SwapchainOwner(
		vk::SwapchainKHR &&swapchain,
		const vk::SurfaceKHR &surface
	) :
		handle{std::move(swapchain)},
		surface{std::move(surface)} {
		handle = vk::SwapchainKHR{};
	}

	SwapchainOwner(SwapchainOwner &&rhs)
		: handle{std::move(rhs.handle)},
		surface{std::move(rhs.surface)} {
		rhs.handle = vk::SwapchainKHR{};
		rhs.surface = vk::SurfaceKHR{};
	}

	SwapchainOwner & operator=(SwapchainOwner &&rhs) {
		destroy();

		handle = std::move(rhs.handle);
		surface = std::move(rhs.surface);

		rhs.handle = vk::SwapchainKHR{};
		rhs.surface = vk::SurfaceKHR{};

		return *this;
	}

	void destroy() {
		if (handle) {
			// handle.destroy();

			handle = vk::SwapchainKHR{};
			surface = vk::SurfaceKHR{};
		}
	}

	SwapchainOwner(const SwapchainOwner &rhs) = delete;
	SwapchainOwner & operator=(const SwapchainOwner &rhs) = delete;

	~SwapchainOwner() {
		destroy();
	}
};

} // vlk

} // rn
