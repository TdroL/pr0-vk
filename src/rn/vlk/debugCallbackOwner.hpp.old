#pragma once

#include <memory>
#include <vulkan/vulkan.hpp>

#include "exts/debugCallbackDispatchTable.hpp"

namespace rn {

namespace vlk {

class DebugCallbackOwner {
public:
	vk::DebugReportCallbackEXT handle{};
	std::unique_ptr<int> logLevel{};
	vk::Instance instance{};

	DebugCallbackOwner() = default;
	DebugCallbackOwner(vk::DebugReportCallbackEXT &&debugCallback, std::unique_ptr<int> &&logLevel, const vk::Instance &instance)
		: handle{std::move(debugCallback)}, logLevel{std::move(logLevel)}, instance{instance} {

		initDebugCallbackDispatchTable(instance);

		debugCallback = vk::DebugReportCallbackEXT{};
	}
	DebugCallbackOwner(DebugCallbackOwner &&rhs)
		: handle{std::move(rhs.handle)}, logLevel{std::move(rhs.logLevel)}, instance{rhs.instance} {
		rhs.handle = vk::DebugReportCallbackEXT{};
	}

	DebugCallbackOwner & operator=(DebugCallbackOwner &&rhs) {
		destroy();

		handle = std::move(rhs.handle);
		logLevel = std::move(rhs.logLevel);
		instance = rhs.instance;

		rhs.handle = vk::DebugReportCallbackEXT{};
		rhs.logLevel.reset();
		rhs.instance = vk::Instance{};

		return *this;
	}

	void destroy() {
		if (handle) {
			instance.destroyDebugReportCallbackEXT(handle);

			releaseDebugCallbackDispatchTable(instance);

			handle = vk::DebugReportCallbackEXT{};
			logLevel.reset();
			instance = vk::Instance{};
		}
	}

	DebugCallbackOwner(const DebugCallbackOwner &rhs) = delete;
	DebugCallbackOwner & operator=(const DebugCallbackOwner &rhs) = delete;

	~DebugCallbackOwner() {
		destroy();
	}
};

} // vlk

} // rn
